[Unit]
Description=Build 763 Cadets backend image

[Build]
ImageTag=localhost/cadets-backend:latest
# Build context = the backend/ dir; File is relative to it.
# CHANGE this to wherever you cloned the repo on this server.
SetWorkingDirectory=/home/alex/cadet763/backend
File=Dockerfile
