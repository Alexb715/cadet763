[Unit]
Description=763 Cadets web gateway (publishes one port, routes /api + serves SPA)
Wants=cadets-backend.service cadets-frontend.service
After=cadets-backend.service cadets-frontend.service

[Container]
ContainerName=cadets-web
# Built by CI (Caddy with Caddyfile baked in) and pulled from GHCR.
Image=ghcr.io/alexb715/cadet763-web:latest
Pull=newer
AutoUpdate=registry
Network=cadets.network
PublishPort=8088:8088/tcp

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=default.target
