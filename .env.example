# --- Environment -------------------------------------------------------------
# 'production' (default) = all hardening on.
# 'development'          = loose CORS, no HSTS, relaxed CSP, verbose errors,
#                          auto-seeded admin (admin/cadet763dev0), short sessions.
#                          NEVER set this in prod — server logs a loud warning.
APP_ENV=production

# --- Proxy integration -------------------------------------------------------
# Pattern A (preferred): your reverse proxy is in Docker, on a shared network.
#   docker network create cadets_proxy
# Then attach your proxy container to it.
PROXY_NETWORK=cadets_proxy

# Pattern B: proxy is on the host. Uncomment the `ports:` blocks in
# docker-compose.yml and set:
# BACKEND_BIND=127.0.0.1
# BACKEND_HOST_PORT=8080
# FRONTEND_BIND=127.0.0.1
# FRONTEND_HOST_PORT=8081

# --- CORS / domain -----------------------------------------------------------
# Origin(s) the frontend is served from. Comma-separated. No trailing slash.
FRONTEND_ORIGIN=https://763aircadets.example.ca

# Optional: build absolute image URLs in /api/posts (e.g. https://763aircadets.example.ca).
# Leave empty to serve relative URLs (works behind any same-origin proxy).
PUBLIC_BASE_URL=

# Optional: CIDRs of proxies whose X-Forwarded-For we trust for rate-limiting.
TRUSTED_PROXIES=

# --- Sessions / auth ---------------------------------------------------------
SESSION_TTL=720h

# --- Facebook ----------------------------------------------------------------
# See README "Getting a Facebook Page Access Token" for how to obtain these.
FB_PAGE_ID=
FB_PAGE_TOKEN=
FB_MIRROR_IMAGES=true

# --- Image garbage collection ------------------------------------------------
# Images that haven't been referenced from the editable content document or any
# post for IMAGE_GC_DAYS get deleted on every IMAGE_GC_INTERVAL tick. Newly
# uploaded images get the full grace window even if not yet assigned to a slot.
IMAGE_GC_DAYS=14
IMAGE_GC_INTERVAL=6h

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info

# --- First-run bootstrap (used only by `cadets-seed`) ------------------------
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASS=replace-with-long-random
ADMIN_BOOTSTRAP_NAME=Capt. Cormier

# --- Build metadata ----------------------------------------------------------
VERSION=dev
